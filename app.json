{
  "expo": {
    "name": "huandao-cockpit",
    "slug": "huandao-cockpit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "huandaocockpit",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tainakanchu.huandaocockpit"
    },
    "android": {
      "package": "com.tainakanchu.huandaocockpit",
      "adaptiveIcon": {
        "backgroundColor": "#145C2E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "環島コックピット",
      "shortName": "環島",
      "description": "台湾環島サイクリングの判断補助アプリ",
      "themeColor": "#1B7A3D",
      "backgroundColor": "#FAF8F5",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "ja"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "環島コックピットはルート上の現在位置を追跡するために位置情報を使用します。",
          "locationWhenInUsePermission": "環島コックピットはルート上の現在位置を追跡するために位置情報を使用します。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
